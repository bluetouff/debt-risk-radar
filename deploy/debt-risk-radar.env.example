# Copy to /etc/debt-risk-radar.env on Debian.
# chmod 600 /etc/debt-risk-radar.env

FRED_API_KEY=
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com

DEBT_RISK_RADAR_LATEST_JSON=/var/www/debt-risk-radar/latest.json
DEBT_RISK_RADAR_LATEST_JSON_TOP_SIGNALS=20

STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
STREAMLIT_SERVER_ADDRESS=127.0.0.1
STREAMLIT_SERVER_PORT=8502
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=true
STREAMLIT_SERVER_ENABLE_CORS=true
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=none
